# Insurance Copilot - Backend Environment Configuration

APP_NAME=Insurance Copilot
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database (Neon PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/insurance_copilot?sslmode=require
DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@ep-xxx.us-east-2.aws.neon.tech/insurance_copilot?sslmode=require

# Clerk Authentication
CLERK_API_KEY=your_clerk_secret_key_here
CLERK_JWT_PUB_KEY=your_clerk_jwks_url_here
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# Groq (Primary LLM)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Tavily Search
TAVILY_API_KEY=tvly-your_tavily_key_here

# Upload Limits
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# RAG Configuration
PGVECTOR_DIMENSION=384
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# CORS - set to your frontend URL on Render
CORS_ORIGINS=["https://your-frontend.onrender.com"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
