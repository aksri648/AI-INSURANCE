# Insurance Copilot - Backend Environment Configuration

# Application
APP_NAME=Insurance Copilot
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/insurance_copilot
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/insurance_copilot

# Clerk Authentication
CLERK_API_KEY=your_clerk_api_key_here
CLERK_JWT_PUB_KEY=your_clerk_jwt_public_key_here
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# Ollama (Primary LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=qwen3:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Groq (Fallback LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_FALLBACK=true

# Tavily Search
TAVILY_API_KEY=your_tavily_api_key_here

# Storage (local or s3)
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Upload Limits
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# RAG Configuration
PGVECTOR_DIMENSION=768
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RETRIEVAL=5

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Sentry (optional)
SENTRY_DSN=
